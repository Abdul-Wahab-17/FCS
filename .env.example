# ==========================================
# Factory Compliance System - Environment Config
# ==========================================

# 1. API Configuration
API_HOST=127.0.0.1
API_PORT=8000
DEBUG=True

# 2. LLM API Keys
# GROQ_API_KEY is required to dynamically parse compliance_policy.pdf
GROQ_API_KEY=gsk_your_groq_api_key_here

# 3. Detection Thresholds
CONFIDENCE_THRESHOLD=0.50
DETECTION_USE_ML=True

# 4. Storage & Output Paths
# (Optional overrides, defaults to project root paths)
# DATABASE_PATH=outputs/violations.db
# OUTPUT_DIR=outputs
# RULES_PATH=src/severity/parsed_rules.json
